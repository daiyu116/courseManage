# ============================================================
# [课程管理系统] Docker 环境变量配置
# 复制此文件为 .env 并修改为你的实际值
# 所有参数均被 docker-compose.yml / docker-compose.deploy.yml 引用
# ============================================================

# ======================== 端口配置 ========================
# 后端 API 对外映射端口（默认 35000）
BACKEND_PORT=35000
# 前端页面对外映射端口（默认 18080）
FRONTEND_PORT=18080

# ======================== Docker 网络 ========================
# 容器内部子网地址段（默认 172.18.16.0/24，若与宿主机网络冲突可修改）
DOCKER_SUBNET=172.18.16.0/24

# ======================== 数据库配置 ========================
# 数据库端口（容器内部，默认 5432，一般无需修改）
DB_PORT=5432
# 数据库名称（默认 cadb）
POSTGRES_DB=cadb
# 数据库用户名（默认 cadbuser）
POSTGRES_USER=cadbuser
# 数据库密码（必须修改！建议使用 24 位随机字母+数字组合）
# Windows PowerShell 生成: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 24 | ForEach-Object {[char]$_})
# Linux Shell 生成: tr -dc A-Za-z0-9 </dev/urandom | head -c 24
POSTGRES_PASSWORD=MIMA2026nicai
# 数据库最大连接数（默认 200）
POSTGRES_MAX_CONNECTIONS=200

# ======================== 应用安全 ========================
# 应用密钥（必须修改！使用 openssl rand -hex 32 生成）
SECRET_KEY=Xk9mP2vL7nQ4wR8tY3uJ6bN0aC1dF5gH9iO2sK4mP6qR8vU0wX2yZ4aB6cD8e
# 允许的跨域来源（多个用逗号分隔，需与 FRONTEND_PORT 对应）
ALLOWED_ORIGINS=http://localhost:18080,http://127.0.0.1:18080

# ======================== 后端性能 ========================
# 数据库连接池大小（默认 10）
DB_POOL_SIZE=10
# 连接池最大溢出（默认 20）
DB_MAX_OVERFLOW=20
# 连接池超时秒数（默认 30）
DB_POOL_TIMEOUT=30
# 连接池回收秒数（默认 1800）
DB_POOL_RECYCLE=1800
# Uvicorn 工作进程数（默认 4，建议设为 CPU 核心数）
UVICORN_WORKERS=4
# 日志级别（debug/info/warning/error，默认 info）
LOG_LEVEL=info

# ======================== 构建镜像源 ========================
# pip 镜像源地址（国内推荐清华源，海外可改为 https://pypi.org/simple）
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# pip 镜像源域名（与 PIP_INDEX_URL 对应，用于 --trusted-host）
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn